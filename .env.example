# Port for the Node.js backend server
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://attendance_user:attendance_password@localhost:5432/attendance_management

# JWT Secret
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Geolocation verification (Optional)
# Campus Latitude and Longitude (e.g. university center)
CAMPUS_LAT=5.6037
CAMPUS_LNG=-0.1870
# Allowed Radius in meters (default 200m)
ALLOWED_RADIUS_METERS=200
# Toggle GPS verification (true/false)
GPS_VERIFICATION_ENABLED=false
